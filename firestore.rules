rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidAppSession(data) {
      return data.participants is list
        && data.targetCount is number
        && data.targetCount >= 4
        && (data.theme == 'light' || data.theme == 'dark')
        && (data.phase == 'PICKING' || data.phase == 'TOURNAMENT' || data.phase == 'RANKINGS')
        && data.updatedAt == request.time
        && (data.logoImage == null || (data.logoImage is string && data.logoImage.size() < 800000))
        && data.keys().hasAll(['participants', 'targetCount', 'theme', 'phase', 'updatedAt']);
    }

    match /sessions/{sessionId} {
      allow read: if true; // Publicly shareable for now
      allow create: if isValidId(sessionId) && isValidAppSession(incoming());
      allow update: if isValidAppSession(incoming());
      allow delete: if false;
    }
  }
}
